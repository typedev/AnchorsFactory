U+01C3 = @baseLC                           # ǃ · LATIN LETTER RETROFLEX CLICK
U+01C4 = @baseUC                           # Ǆ · LATIN CAPITAL LETTER DZ WITH CARON
U+01C5 = @baseLC                           # ǅ · LATIN CAPITAL LETTER D WITH SMALL LETTER Z WITH CARON
U+01C6 = @baseLC                           # ǆ · LATIN SMALL LETTER DZ WITH CARON
U+01C7 = @baseUC                           # Ǉ · LATIN CAPITAL LETTER LJ
U+01C8 = @baseLC                           # ǈ · LATIN CAPITAL LETTER L WITH SMALL LETTER J
U+01C9 = @baseLC                           # ǉ · LATIN SMALL LETTER LJ
U+01CA = @baseUC                           # Ǌ · LATIN CAPITAL LETTER NJ
U+01CB = @baseLC                           # ǋ · LATIN CAPITAL LETTER N WITH SMALL LETTER J
U+01CC = @baseLC                           # ǌ · LATIN SMALL LETTER NJ
