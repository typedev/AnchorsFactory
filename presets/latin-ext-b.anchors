# AnchorsFactory — Latin Extended-B
#
# GENERATED from the Unicode database by the maintainer's generator
# (dev/gen_latin_rules.py) — do not hand-edit; layer your own rules on top.
#
# Glyphs are addressed by codepoint — except the ASCII letters, which every
# font names alike — so the rules assume no naming scheme.
#
# Uppercase bases anchor at capHeight, lowercase at the cap/x midpoint, and
# marks attach at that same midpoint: one mark set serves both cases and a
# composite never shifts. Round lowercase letters centre on the outline
# crossing instead of the bounding box.
#
# Marks carry their own top/bottom anchor as well as the _top/_bottom they
# attach by: that is what lets accents stack (an acute over a circumflex),
# since a composite inherits the anchors of its last component.

!propagate = composites   # composites inherit their components' anchors

# ============================================================
#  VARIABLES
# ============================================================
&capxMid = capHeight*1/2+xHeight*1/2   # lowercase top / mark height

# ============================================================
#  LABELS — the anchor vocabulary
# ============================================================
@baseUC     = top (box.center capHeight), bottom (box.center 0)
@baseLC     = top (box.center &capxMid), bottom (box.center 0)
@ogonek     = ogonek (outline.right 0)
@horn       = horn (outline.right xHeight)
# marks: _top/_bottom is where the mark attaches, top/bottom where the next
# mark stacks on it
@_top       = _top (box.center &capxMid), top (box.center box.top)
@_topInk    = _top (outline.center@bottom &capxMid), top (box.center box.top)
@_bottom    = _bottom (box.center 0), bottom (box.center box.bottom)
# the capital-height accent set, which a font carries under a name only
@_capTop    = _top (box.center capHeight), top (box.center box.top)
@_capTopInk = _top (outline.center@bottom capHeight), top (box.center box.top)
@_ogonek    = _ogonek (outline.right 0)
@_horn      = _horn (outline.left 0)
@stackTop   = top (box.center box.top)

# ============================================================
#  BASE GLYPHS
# ============================================================
U+0180 = @baseLC                           # ƀ · LATIN SMALL LETTER B WITH STROKE
U+0181 = @baseUC                           # Ɓ · LATIN CAPITAL LETTER B WITH HOOK
U+0182 = @baseUC                           # Ƃ · LATIN CAPITAL LETTER B WITH TOPBAR
U+0183 = @baseLC                           # ƃ · LATIN SMALL LETTER B WITH TOPBAR
U+0184 = @baseUC                           # Ƅ · LATIN CAPITAL LETTER TONE SIX
U+0185 = @baseLC                           # ƅ · LATIN SMALL LETTER TONE SIX
U+0186 = @baseUC                           # Ɔ · LATIN CAPITAL LETTER OPEN O
U+0187 = @baseUC                           # Ƈ · LATIN CAPITAL LETTER C WITH HOOK
U+0188 = @baseLC                           # ƈ · LATIN SMALL LETTER C WITH HOOK
U+0189 = @baseUC                           # Ɖ · LATIN CAPITAL LETTER AFRICAN D
U+018A = @baseUC                           # Ɗ · LATIN CAPITAL LETTER D WITH HOOK
U+018B = @baseUC                           # Ƌ · LATIN CAPITAL LETTER D WITH TOPBAR
U+018C = @baseLC                           # ƌ · LATIN SMALL LETTER D WITH TOPBAR
U+018D = @baseLC                           # ƍ · LATIN SMALL LETTER TURNED DELTA
U+018E = @baseUC                           # Ǝ · LATIN CAPITAL LETTER REVERSED E
U+018F = @baseUC                           # Ə · LATIN CAPITAL LETTER SCHWA
U+0190 = @baseUC                           # Ɛ · LATIN CAPITAL LETTER OPEN E
U+0191 = @baseUC                           # Ƒ · LATIN CAPITAL LETTER F WITH HOOK
U+0192 = @baseLC                           # ƒ · LATIN SMALL LETTER F WITH HOOK
U+0193 = @baseUC                           # Ɠ · LATIN CAPITAL LETTER G WITH HOOK
U+0194 = @baseUC                           # Ɣ · LATIN CAPITAL LETTER GAMMA
U+0195 = @baseLC                           # ƕ · LATIN SMALL LETTER HV
U+0196 = @baseUC                           # Ɩ · LATIN CAPITAL LETTER IOTA
U+0197 = @baseUC                           # Ɨ · LATIN CAPITAL LETTER I WITH STROKE
U+0198 = @baseUC                           # Ƙ · LATIN CAPITAL LETTER K WITH HOOK
U+0199 = @baseLC                           # ƙ · LATIN SMALL LETTER K WITH HOOK
U+019A = @baseLC                           # ƚ · LATIN SMALL LETTER L WITH BAR
U+019B = @baseLC                           # ƛ · LATIN SMALL LETTER LAMBDA WITH STROKE
U+019C = @baseUC                           # Ɯ · LATIN CAPITAL LETTER TURNED M
U+019D = @baseUC                           # Ɲ · LATIN CAPITAL LETTER N WITH LEFT HOOK
