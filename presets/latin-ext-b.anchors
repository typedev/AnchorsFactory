U+01F2 = @baseLC                           # ǲ · LATIN CAPITAL LETTER D WITH SMALL LETTER Z
U+01F3 = @baseLC                           # ǳ · LATIN SMALL LETTER DZ
U+01F6 = @baseUC                           # Ƕ · LATIN CAPITAL LETTER HWAIR
U+01F7 = @baseUC                           # Ƿ · LATIN CAPITAL LETTER WYNN
U+021C = @baseUC                           # Ȝ · LATIN CAPITAL LETTER YOGH
U+021D = @baseLC                           # ȝ · LATIN SMALL LETTER YOGH
U+0220 = @baseUC                           # Ƞ · LATIN CAPITAL LETTER N WITH LONG RIGHT LEG
U+0221 = @baseLC                           # ȡ · LATIN SMALL LETTER D WITH CURL
U+0222 = @baseUC                           # Ȣ · LATIN CAPITAL LETTER OU
U+0223 = @baseLC                           # ȣ · LATIN SMALL LETTER OU
U+0224 = @baseUC                           # Ȥ · LATIN CAPITAL LETTER Z WITH HOOK
U+0225 = @baseLC                           # ȥ · LATIN SMALL LETTER Z WITH HOOK
U+0234 = @baseLC                           # ȴ · LATIN SMALL LETTER L WITH CURL
U+0235 = @baseLC                           # ȵ · LATIN SMALL LETTER N WITH CURL
U+0236 = @baseLC                           # ȶ · LATIN SMALL LETTER T WITH CURL
