U+01A4 = @baseUC                           # Ƥ · LATIN CAPITAL LETTER P WITH HOOK
U+01A5 = @baseLC                           # ƥ · LATIN SMALL LETTER P WITH HOOK
U+01A6 = @baseUC                           # Ʀ · LATIN LETTER YR
U+01A7 = @baseUC                           # Ƨ · LATIN CAPITAL LETTER TONE TWO
U+01A8 = @baseLC                           # ƨ · LATIN SMALL LETTER TONE TWO
U+01A9 = @baseUC                           # Ʃ · LATIN CAPITAL LETTER ESH
U+01AA = @baseLC                           # ƪ · LATIN LETTER REVERSED ESH LOOP
U+01AB = @baseLC                           # ƫ · LATIN SMALL LETTER T WITH PALATAL HOOK
U+01AC = @baseUC                           # Ƭ · LATIN CAPITAL LETTER T WITH HOOK
U+01AD = @baseLC                           # ƭ · LATIN SMALL LETTER T WITH HOOK
U+01AE = @baseUC                           # Ʈ · LATIN CAPITAL LETTER T WITH RETROFLEX HOOK
U+01B1 = @baseUC                           # Ʊ · LATIN CAPITAL LETTER UPSILON
U+01B2 = @baseUC                           # Ʋ · LATIN CAPITAL LETTER V WITH HOOK
U+01B3 = @baseUC                           # Ƴ · LATIN CAPITAL LETTER Y WITH HOOK
U+01B4 = @baseLC                           # ƴ · LATIN SMALL LETTER Y WITH HOOK
U+01B5 = @baseUC                           # Ƶ · LATIN CAPITAL LETTER Z WITH STROKE
U+01B6 = @baseLC                           # ƶ · LATIN SMALL LETTER Z WITH STROKE
U+01B7 = @baseUC                           # Ʒ · LATIN CAPITAL LETTER EZH
U+01B8 = @baseUC                           # Ƹ · LATIN CAPITAL LETTER EZH REVERSED
U+01B9 = @baseLC                           # ƹ · LATIN SMALL LETTER EZH REVERSED
U+01BA = @baseLC                           # ƺ · LATIN SMALL LETTER EZH WITH TAIL
U+01BB = @baseLC                           # ƻ · LATIN LETTER TWO WITH STROKE
U+01BC = @baseUC                           # Ƽ · LATIN CAPITAL LETTER TONE FIVE
U+01BD = @baseLC                           # ƽ · LATIN SMALL LETTER TONE FIVE
U+01BE = @baseLC                           # ƾ · LATIN LETTER INVERTED GLOTTAL STOP WITH STROKE
