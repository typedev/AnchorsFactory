U+0238 = @baseLC                           # ȸ · LATIN SMALL LETTER DB DIGRAPH
U+0239 = @baseLC                           # ȹ · LATIN SMALL LETTER QP DIGRAPH
U+023A = @baseUC                           # Ⱥ · LATIN CAPITAL LETTER A WITH STROKE
U+023B = @baseUC                           # Ȼ · LATIN CAPITAL LETTER C WITH STROKE
U+023C = @baseLC                           # ȼ · LATIN SMALL LETTER C WITH STROKE
U+023D = @baseUC                           # Ƚ · LATIN CAPITAL LETTER L WITH BAR
U+023E = @baseUC                           # Ⱦ · LATIN CAPITAL LETTER T WITH DIAGONAL STROKE
U+023F = @baseLC                           # ȿ · LATIN SMALL LETTER S WITH SWASH TAIL
U+0240 = @baseLC                           # ɀ · LATIN SMALL LETTER Z WITH SWASH TAIL
U+0241 = @baseUC                           # Ɂ · LATIN CAPITAL LETTER GLOTTAL STOP
U+0242 = @baseLC                           # ɂ · LATIN SMALL LETTER GLOTTAL STOP
U+0243 = @baseUC                           # Ƀ · LATIN CAPITAL LETTER B WITH STROKE
U+0244 = @baseUC                           # Ʉ · LATIN CAPITAL LETTER U BAR
U+0245 = @baseUC                           # Ʌ · LATIN CAPITAL LETTER TURNED V
U+0246 = @baseUC                           # Ɇ · LATIN CAPITAL LETTER E WITH STROKE
U+0247 = @baseLC                           # ɇ · LATIN SMALL LETTER E WITH STROKE
U+0248 = @baseUC                           # Ɉ · LATIN CAPITAL LETTER J WITH STROKE
U+0249 = @baseLC                           # ɉ · LATIN SMALL LETTER J WITH STROKE
U+024A = @baseUC                           # Ɋ · LATIN CAPITAL LETTER SMALL Q WITH HOOK TAIL
U+024B = @baseLC                           # ɋ · LATIN SMALL LETTER Q WITH HOOK TAIL
U+024C = @baseUC                           # Ɍ · LATIN CAPITAL LETTER R WITH STROKE
U+024D = @baseLC                           # ɍ · LATIN SMALL LETTER R WITH STROKE
U+024E = @baseUC                           # Ɏ · LATIN CAPITAL LETTER Y WITH STROKE
U+024F = @baseLC                           # ɏ · LATIN SMALL LETTER Y WITH STROKE

# Bases from another block that this one's composites lean on:
# `+=` so the set that owns them keeps its top/bottom.
# ------------------------------------------------------------
O += @ogonek, @horn
U += @horn
o += @ogonek, @horn
u += @horn

# Bases that are themselves precomposed (ế = ê + acute): anchored on
# their own ink, and `+=` so an inherited anchor set survives.
# ------------------------------------------------------------
U+00C4 += @stackTop                        # Ä · LATIN CAPITAL LETTER A WITH DIAERESIS
U+00C5 += @stackTop                        # Å · LATIN CAPITAL LETTER A WITH RING ABOVE
U+00D5 += @stackTop                        # Õ · LATIN CAPITAL LETTER O WITH TILDE
U+00D6 += @stackTop                        # Ö · LATIN CAPITAL LETTER O WITH DIAERESIS
U+00DC += @stackTop                        # Ü · LATIN CAPITAL LETTER U WITH DIAERESIS
U+00E4 += @stackTop                        # ä · LATIN SMALL LETTER A WITH DIAERESIS
U+00E5 += @stackTop                        # å · LATIN SMALL LETTER A WITH RING ABOVE
U+00F5 += @stackTop                        # õ · LATIN SMALL LETTER O WITH TILDE
U+00F6 += @stackTop                        # ö · LATIN SMALL LETTER O WITH DIAERESIS
U+00FC += @stackTop                        # ü · LATIN SMALL LETTER U WITH DIAERESIS
U+01EA += @stackTop                        # Ǫ · LATIN CAPITAL LETTER O WITH OGONEK
U+01EB += @stackTop                        # ǫ · LATIN SMALL LETTER O WITH OGONEK
U+0226 += @stackTop                        # Ȧ · LATIN CAPITAL LETTER A WITH DOT ABOVE
U+0227 += @stackTop                        # ȧ · LATIN SMALL LETTER A WITH DOT ABOVE
U+022E += @stackTop                        # Ȯ · LATIN CAPITAL LETTER O WITH DOT ABOVE
U+022F += @stackTop                        # ȯ · LATIN SMALL LETTER O WITH DOT ABOVE

# ============================================================
#  MARKS — the combining mark and the spacing accent alike, since a
#  font may encode either
# ============================================================
U+0300 = @_topInk                          # ◌̀ · COMBINING GRAVE ACCENT
U+0060 = @_topInk                          # ` · GRAVE ACCENT
U+0301 = @_topInk                          # ◌́ · COMBINING ACUTE ACCENT
U+00B4 = @_topInk                          # ´ · ACUTE ACCENT
U+0304 = @_top                             # ◌̄ · COMBINING MACRON
U+00AF = @_top                             # ¯ · MACRON
U+0307 = @_top                             # ◌̇ · COMBINING DOT ABOVE
U+02D9 = @_top                             # ˙ · DOT ABOVE
U+030C = @_top                             # ◌̌ · COMBINING CARON
U+02C7 = @_top                             # ˇ · CARON
U+030F = @_topInk                          # ◌̏ · COMBINING DOUBLE GRAVE ACCENT
U+0311 = @_top                             # ◌̑ · COMBINING INVERTED BREVE
U+031B = @_horn                            # ◌̛ · COMBINING HORN
U+0326 = @_bottom                          # ◌̦ · COMBINING COMMA BELOW
U+F6C3 = @_bottom                          # · · COMMA ACCENT (Adobe private use)
U+0327 = @_bottom                          # ◌̧ · COMBINING CEDILLA
U+00B8 = @_bottom                          # ¸ · CEDILLA
U+0328 = @_ogonek                          # ◌̨ · COMBINING OGONEK
U+02DB = @_ogonek                          # ˛ · OGONEK

# ============================================================
#  LEGACY MARK NAMES — the same marks, by name
#
#  Plenty of fonts ship accents the codepoint rules above cannot reach:
#  an unencoded combining set, or a second, capital-height set that has
#  no codepoints at all. These are the conventional names for both. A
#  font that lacks them simply matches nothing.
# ============================================================
grave = @_topInk ; gravecomb = @_topInk
Grave = @_capTopInk ; grave.case = @_capTopInk ; gravecomb.case = @_capTopInk
acute = @_topInk ; acutecomb = @_topInk
Acute = @_capTopInk ; acute.case = @_capTopInk ; acutecomb.case = @_capTopInk
macron = @_top ; macroncomb = @_top
Macron = @_capTop ; macron.case = @_capTop ; macroncomb.case = @_capTop
dotaccent = @_top ; dotaccentcomb = @_top
Dotaccent = @_capTop ; dotaccent.case = @_capTop ; dotaccentcomb.case = @_capTop
caron = @_top ; caroncomb = @_top
Caron = @_capTop ; caron.case = @_capTop ; caroncomb.case = @_capTop
horn = @_horn ; horncomb = @_horn
Horn = @_horn ; horn.case = @_horn ; horncomb.case = @_horn
commaaccent = @_bottom ; commaaccentcomb = @_bottom
Commaaccent = @_bottom ; commaaccent.case = @_bottom ; commaaccentcomb.case = @_bottom
cedilla = @_bottom ; cedillacomb = @_bottom
Cedilla = @_bottom ; cedilla.case = @_bottom ; cedillacomb.case = @_bottom
ogonek = @_ogonek ; ogonekcomb = @_ogonek
Ogonek = @_ogonek ; ogonek.case = @_ogonek ; ogonekcomb.case = @_ogonek
