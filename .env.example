# Publish tokens for `make release` / `make release-test`.
#
# Copy this file to `.env` (which is gitignored — never commit real tokens)
# and fill in your PyPI / TestPyPI API tokens:
#
#     cp .env.example .env
#
# Create tokens at:
#   PyPI     → https://pypi.org/manage/account/token/
#   TestPyPI → https://test.pypi.org/manage/account/token/
#
# release.py reads the environment first, then this file, and finally prompts
# interactively if a token is missing. `make release` uses PYPI_TOKEN;
# `make release-test` uses TEST_PYPI_TOKEN.

PYPI_TOKEN=pypi-xxxxxxxxxxxxxxxxxxxxxxxx
TEST_PYPI_TOKEN=pypi-xxxxxxxxxxxxxxxxxxxxxxxx
